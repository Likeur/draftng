---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

const template = {
  name: "Foodyng",
  status: "Active",
  category: "Restaurant Management",
  desc: "A premium, restaurant management UI dashboard template built with Angular 22+ and Tailwind CSS v4.",
  fullDesc: "Foodyng is a high-end, modern, and ultra-high-performance restaurant management dashboard template built with Angular 22+ and Tailwind CSS v4. Inspired by the minimalist and productive aesthetics of Notion, combined with polished glassmorphism effects and smooth micro-animations, it offers an outstanding user experience and a premium design that captures attention at first glance.",
  tech: ["Angular 22+", "Tailwind v4", "Signals", "ApexCharts", "Multi-theme"],
  github: "https://store.draftng.xyz/prd_9mgwfss0",
  demo: "https://foodyng.vercel.app/dashboard",
  image: "/project/foodyng.png",
  date: "28 Jun 2026",
  price: "Premium"
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/brand/draftngfavikon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-XX4LE51V8Q"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-XX4LE51V8Q');
		</script>
		<title>Foodyng - Angular Restaurant Management Dashboard | draftNG</title>
		
		<!-- SEO Meta Tags -->
		<link rel="canonical" href="https://draftng.com/foodyng" />
		<meta name="description" content="Foodyng - Premium Angular 22+ restaurant management dashboard template with Notion-inspired aesthetics, 4 built-in themes, order tracking, and inventory management. Built with Tailwind CSS v4." />
		<meta name="keywords" content="Angular 22, restaurant dashboard, POS simulator, Notion design, Tailwind CSS v4, Angular template, menu editor, reservation system" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://draftng.com/foodyng" />
		<meta property="og:title" content="Foodyng - Angular Restaurant Management Dashboard | draftNG" />
		<meta property="og:description" content="Premium Angular 22+ restaurant management dashboard template with Notion-inspired aesthetics, 4 built-in themes, order tracking, and inventory management." />
		<meta property="og:image" content="https://draftng.com/draftOG.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://draftng.com/foodyng" />
		<meta property="twitter:title" content="Foodyng - Angular Restaurant Management Dashboard | draftNG" />
		<meta property="twitter:description" content="Premium Angular 22+ restaurant management dashboard template with Notion-inspired aesthetics, 4 built-in themes, order tracking, and inventory management." />
		<meta property="twitter:image" content="https://draftng.com/draftOG.png" />

		<!-- Structured Data (JSON-LD) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "SoftwareApplication",
				"name": "Foodyng",
				"operatingSystem": "Web",
				"applicationCategory": "BusinessApplication",
				"description": "A premium, comprehensive restaurant management UI dashboard template built with Angular 22+ and Tailwind CSS v4. Features 4 customizable Notion-style themes, POS simulator, live order tracking, menu editors, table reservations, and raw material inventory.",
				"offers": {
					"@type": "Offer",
					"priceCurrency": "USD",
					"availability": "https://schema.org/InStock"
				},
				"applicationSubCategory": "Restaurant Management Dashboard",
				"featureList": ["Notion Multi-theme Support", "Live Order Lifecycle Tracking", "POS Bill Receipt Simulator", "CRUD Menu Editor", "Shift Scheduler", "Inventory Raw Stock Alerts"],
				"programmingLanguage": ["TypeScript", "Angular"],
				"author": {
					"@type": "Organization",
					"name": "draftNG",
					"url": "https://draftng.com"
				}
			}
		</script>
	</head>
	<body class="bg-zinc-950 text-zinc-100 selection:bg-zinc-100 selection:text-zinc-950 font-sans min-h-screen">
		<div class="max-w-4xl mx-auto px-6 py-12">
			<a href="/" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors mb-8">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
				Back to Templates
			</a>

			<div class="space-y-8">
				<div>
					<h1 class="font-bold text-4xl lg:text-5xl text-zinc-50 mb-4" style="font-family: var(--font-display)">{template.name}</h1>
					<div class="flex items-center gap-3 mb-4">
						<span class="text-xs font-bold tracking-wider uppercase bg-gradient-to-r from-amber-500/20 to-orange-500/20 text-amber-300 px-3 py-1 rounded border border-amber-500/30">
							{template.price}
						</span>
						<span class="text-zinc-400 text-sm">{template.category}</span>
					</div>
					<p class="text-zinc-300 text-lg leading-relaxed">{template.fullDesc}</p>
				</div>

				{template.image && (
					<div class="w-full rounded-xl overflow-hidden bg-zinc-900 border border-zinc-800 relative shadow-lg">
						<img src={template.image} alt={template.name} class="w-full h-auto block" />
					</div>
				)}

				<div class="flex items-center gap-4 pt-2">
					<a href={template.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-950 hover:text-black transition-colors bg-zinc-100 hover:bg-white px-6 py-3 rounded-lg shadow-sm font-semibold">
						Buy Template
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
					</a>
					<a href={template.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors px-6 py-3 rounded-lg font-semibold">
						Live Preview
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</a>
				</div>

				<div class="space-y-4">
					<h2 class="font-bold text-2xl text-zinc-200" style="font-family: var(--font-display)">Rich & Interactive Business Features</h2>
					<ul class="space-y-3 text-zinc-400">
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Overview Dashboard:</strong> Key performance indicators (Revenue, average ticket size, active tables, visitor statistics), interactive 7-day sales charts, and real-time activity feeds.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Orders Registry & POS Simulator:</strong> Complete order lifecycle management (Pending, Preparing, Served, Paid), detailed side billing drawer (dynamic calculations for subtotal, 10% VAT, and grand total), table and waiter assignments, and a print invoice simulator (generates a receipt styled like a physical cash register ticket).</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Menu Catalog:</strong> Categorized menu sorting (Appetizers, Mains, Desserts, Drinks), full CRUD management (add, edit, and delete dishes with pricing, allergen lists, descriptions, and photos), quick diet filters (Vegetarian, Vegan, Gluten-Free), and live availability toggle.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Staff Shift List & Schedules:</strong> Full staff profiles (role, phone number, email address), guard duty scheduling (Shift Start / Shift End), and a quick check-in presence toggle (On Shift / Off Duty).</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Inventory & Stock Alerts:</strong> Raw materials tracking by unit (kg, liters, pieces), visual color-coded stock level progress bars, automatic low stock warning based on custom critical thresholds, and real-time total inventory valuation tracking.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Reservations & Pax:</strong> Table occupancy rate tracking, chronological client reservation lists with guest headcount (pax) and table status.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Administration & Settings:</strong> User management table with last seen timestamps, restaurant profile configuration menu, and multi-language switch (fully translated English / French).</span>
						</li>
					</ul>
				</div>

				<div class="space-y-4">
					<h2 class="font-bold text-2xl text-zinc-200" style="font-family: var(--font-display)">Premium & Customizable Design</h2>
					<ul class="space-y-3 text-zinc-400">
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Built-in Multi-theme Support:</strong> Switch with one click between 4 refined themes: Notion Light (clean & bright), Notion Dark (relaxing dark mode), Cozy Amber (warm & welcoming), and Forest Mint (fresh & eco-friendly).</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Staggered Entrance Animations:</strong> Delayed and progressive entry animations on all lists for a premium feel.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Fully Responsive:</strong> Optimized for mobile, tablet, and large screens. Includes a collapsible sidebar and mobile drawer navigation.</span>
						</li>
					</ul>
				</div>

				<div class="space-y-4">
					<h2 class="font-bold text-2xl text-zinc-200" style="font-family: var(--font-display)">Modern & High-Performance Tech Stack</h2>
					<ul class="space-y-3 text-zinc-400">
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Angular 22+ Standalone:</strong> 100% Standalone Component structure following modern best practices. Each file is clean, commented, and optimized.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Angular Signals:</strong> Powered by Signals (signal, computed), eliminating complex RxJS patterns for instant reactive rendering and minimal memory footprint.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Tailwind CSS v4 & CSS Variables:</strong> Sleek integration utilizing Tailwind's CSS-first theme configuration and utility engine.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">ApexCharts:</strong> Fluid, dynamic charts integrated seamlessly for restaurant analytics.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">AI Coding Assistant Friendly:</strong> Includes a dedicated `AI_GUIDELINES.md` file designed to feed context to your LLM or AI coding agent when extending features.</span>
						</li>
					</ul>
				</div>

				<div class="space-y-4">
					<h2 class="font-bold text-2xl text-zinc-200" style="font-family: var(--font-display)">What's Included</h2>
					<ul class="space-y-2 text-zinc-400">
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Full source code (Angular 22+ / Tailwind CSS v4 / Vitest)
						</li>
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Structured Mock Database Services (OrderService, MenuService, ShiftService, InventoryService)
						</li>
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Dedicated Developer & AI customization guidelines (AI_GUIDELINES.md)
						</li>
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Commercial License template
						</li>
					</ul>
				</div>

				<div class="space-y-4">
					<h2 class="font-bold text-2xl text-zinc-200" style="font-family: var(--font-display)">Tech Stack</h2>
					<div class="flex flex-wrap gap-2">
						{template.tech.map(tech => (
							<span class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-zinc-900 text-zinc-300 border border-zinc-800">{tech}</span>
						))}
					</div>
				</div>
			</div>
		</div>
		<Analytics />
	</body>
</html>
