---
import '../../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date | undefined) => {
  if (!date) return 'Unknown date';
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/brand/draftngfavikon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{post.data.title} | draftNG Blog</title>

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-XX4LE51V8Q"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-XX4LE51V8Q');
		</script>
		
		<!-- SEO Meta Tags -->
		<link rel="canonical" href={`https://draftng.xyz/blog/${post.id}`} />
		<meta name="description" content={post.data.description || ''} />
		<meta name="keywords" content={(post.data.tags || []).join(', ')} />
		<meta name="author" content={post.data.author || ''} />
		<meta name="article:published_time" content={post.data.date?.toISOString() || ''} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="article" />
		<meta property="og:url" content={`https://draftng.xyz/blog/${post.id}`} />
		<meta property="og:title" content={post.data.title || ''} />
		<meta property="og:description" content={post.data.description || ''} />
		<meta property="og:article:published_time" content={post.data.date?.toISOString() || ''} />
		<meta property="og:article:author" content={post.data.author || ''} />
		<meta property="og:article:tag" content={(post.data.tags || []).join(', ')} />
		<meta property="og:image" content={`https://draftng.xyz/og/blog/${post.id}.png`} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={`https://draftng.xyz/blog/${post.id}`} />
		<meta property="twitter:title" content={post.data.title || ''} />
		<meta property="twitter:description" content={post.data.description || ''} />
		<meta property="twitter:image" content={`https://draftng.xyz/og/blog/${post.id}.png`} />

		<!-- Article Schema -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": post.data.title || '',
			"description": post.data.description || '',
			"author": {
				"@type": "Person",
				"name": post.data.author || ''
			},
			"datePublished": post.data.date?.toISOString() || '',
			"dateModified": post.data.date?.toISOString() || '',
			"keywords": (post.data.tags || []).join(', '),
			"mainEntityOfPage": {
				"@type": "WebPage",
				"@id": `https://draftng.xyz/blog/${post.id}`
			},
			"publisher": {
				"@type": "Organization",
				"name": "draftNG",
				"url": "https://draftng.xyz"
			}
		})} />
	</head>
	<body class="bg-zinc-950 text-zinc-100 selection:bg-zinc-100 selection:text-zinc-950 font-sans min-h-screen">
		<div class="max-w-4xl mx-auto px-6 py-12">
			<a href="/blog" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors mb-8">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
				Back to Blog
			</a>

			<article class="space-y-8">
				<header class="space-y-4">
					<div class="flex items-center gap-2 text-sm text-zinc-500">
						<time datetime={post.data.date?.toISOString() || ''}>
							{formatDate(post.data.date)}
						</time>
						<span>•</span>
						<span>{post.data.author || ''}</span>
					</div>
					<h1 class="font-bold text-4xl lg:text-5xl text-zinc-50 leading-tight" style="font-family: var(--font-display)">
						{post.data.title || ''}
					</h1>
					<p class="text-zinc-400 text-lg leading-relaxed">
						{post.data.description || ''}
					</p>
					<div class="flex flex-wrap gap-2">
						{(post.data.tags || []).map((tag) => (
							<span class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-zinc-900 text-zinc-400 border border-zinc-800">
								{tag}
							</span>
						))}
					</div>
				</header>

				<div class="prose prose-invert prose-lg max-w-none">
					<Content />
				</div>
			</article>
		</div>
		<Analytics />
		<SpeedInsights />
	</body>
</html>

<style is:global>
	.prose {
		max-width: 100%;
		font-size: 1.0625rem;
		line-height: 1.8;
		color: #a1a1aa;
	}
	.prose h1 {
		font-weight: 800;
		font-size: 2.25rem;
		color: #fafaf9;
		margin-top: 3.5rem;
		margin-bottom: 1.5rem;
		font-family: var(--font-display);
		line-height: 1.2;
		letter-spacing: -0.02em;
	}
	.prose h2 {
		font-weight: 700;
		font-size: 1.875rem;
		color: #e4e4e7;
		margin-top: 3rem;
		margin-bottom: 1.25rem;
		font-family: var(--font-display);
		line-height: 1.3;
		letter-spacing: -0.01em;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid #27272a;
	}
	.prose h3 {
		font-weight: 600;
		font-size: 1.5rem;
		color: #d4d4d8;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		font-family: var(--font-display);
		line-height: 1.4;
	}
	.prose h4 {
		font-weight: 600;
		font-size: 1.25rem;
		color: #a1a1aa;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		font-family: var(--font-display);
		line-height: 1.4;
	}
	.prose p {
		color: #a1a1aa;
		line-height: 1.85;
		margin-bottom: 1.75rem;
		font-size: 1.0625rem;
	}
	.prose ul {
		list-style-type: disc;
		list-style-position: outside;
		margin-bottom: 1.75rem;
		margin-top: 1rem;
		padding-left: 1.75rem;
		color: #a1a1aa;
	}
	.prose ul li {
		margin-bottom: 0.875rem;
		line-height: 1.75;
		padding-left: 0.25rem;
	}
	.prose ul li::marker {
		color: #52525b;
	}
	.prose ol {
		list-style-type: decimal;
		list-style-position: outside;
		margin-bottom: 1.75rem;
		margin-top: 1rem;
		padding-left: 1.75rem;
		color: #a1a1aa;
	}
	.prose ol li {
		margin-bottom: 0.875rem;
		line-height: 1.75;
		padding-left: 0.25rem;
	}
	.prose ol li::marker {
		color: #52525b;
		font-weight: 600;
	}
	.prose code {
		background-color: #27272a;
		color: #f0f0f0;
		padding: 0.2rem 0.45rem;
		border-radius: 0.375rem;
		font-size: 0.9em;
		font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
		border: 1px solid #3f3f46;
	}
	.prose pre {
		background-color: #0a0a0b;
		border: 1px solid #27272a;
		border-radius: 0.75rem;
		padding: 1.5rem 1.75rem;
		margin: 2.5rem 0;
		overflow-x: auto;
		position: relative;
	}
	.prose pre code {
		background-color: transparent;
		padding: 0;
		font-size: 0.9rem;
		line-height: 1.75;
		border: none;
		color: #e4e4e7;
		font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
	}
	.prose a {
		color: #60a5fa;
		text-decoration: underline;
		text-underline-offset: 2px;
		font-weight: 500;
	}
	.prose a:hover {
		color: #93c5fd;
		text-decoration-thickness: 2px;
	}
	.prose strong {
		color: #e4e4e7;
		font-weight: 600;
	}
	.prose blockquote {
		border-left: 4px solid #6366f1;
		padding: 1.25rem 1.75rem;
		font-style: italic;
		color: #d4d4d8;
		margin: 2.5rem 0;
		background-color: #18181b;
		border-radius: 0 0.5rem 0.5rem 0;
		line-height: 1.7;
	}
	.prose blockquote p {
		margin-bottom: 0;
	}
	.prose hr {
		border: none;
		border-top: 1px solid #27272a;
		margin: 3.5rem 0;
	}
	.prose table {
		width: 100%;
		border-collapse: collapse;
		margin: 2.5rem 0;
		font-size: 0.95rem;
	}
	.prose th {
		background-color: #18181b;
		color: #e4e4e7;
		padding: 0.875rem 1.25rem;
		text-align: left;
		font-weight: 600;
		border-bottom: 2px solid #3f3f46;
	}
	.prose td {
		padding: 0.875rem 1.25rem;
		border-bottom: 1px solid #27272a;
		color: #a1a1aa;
		line-height: 1.6;
	}
	.prose tr:last-child td {
		border-bottom: none;
	}
	.prose table + p,
	.prose pre + p,
	.prose ul + p,
	.prose ol + p,
	.prose blockquote + p {
		margin-top: 1.75rem;
	}
</style>
