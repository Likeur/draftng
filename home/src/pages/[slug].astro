---
import { getCollection, render } from 'astro:content';
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

export async function getStaticPaths() {
  const templates = await getCollection('templates');
  return templates.map(tpl => ({
    params: { slug: tpl.id },
    props: { template: tpl.data, entry: tpl },
  }));
}

const { template, entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id;

// Dynamic SEO tags
const seoTitle = `${template.name} - Angular ${template.category} Dashboard Template | draftNG`;
const seoDescription = `${template.name} - ${template.price} Angular 22+ ${template.category.toLowerCase()} dashboard template. ${template.desc}`;
const canonicalUrl = `https://draftng.com/${slug}`;

// Dynamic JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": template.name,
  "operatingSystem": "Web",
  "applicationCategory": template.price === 'Free' ? "DeveloperApplication" : "BusinessApplication",
  "description": template.fullDesc,
  "offers": template.price === 'Free' ? {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  } : {
    "@type": "Offer",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  },
  "applicationSubCategory": `${template.category} Dashboard`,
  "programmingLanguage": ["TypeScript", "Angular"],
  "author": {
    "@type": "Organization",
    "name": "draftNG",
    "url": "https://draftng.com"
  }
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/brand/draftngfavikon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-XX4LE51V8Q"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-XX4LE51V8Q');
		</script>
		<title>{seoTitle}</title>
		
		<!-- SEO Meta Tags -->
		<link rel="canonical" href={canonicalUrl} />
		<meta name="description" content={seoDescription} />
		<meta name="keywords" content={`Angular 22, ${template.category.toLowerCase()}, dashboard, Tailwind CSS v4, Angular template`} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={seoTitle} />
		<meta property="og:description" content={seoDescription} />
		<meta property="og:image" content="https://draftng.com/draftOG.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={seoTitle} />
		<meta property="twitter:description" content={seoDescription} />
		<meta property="twitter:image" content="https://draftng.com/draftOG.png" />

		<!-- Structured Data (JSON-LD) -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="bg-zinc-950 text-zinc-100 selection:bg-zinc-100 selection:text-zinc-950 font-sans min-h-screen">
		<div class="max-w-4xl mx-auto px-6 py-12">
			<a href="/" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors mb-8">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
				Back to Templates
			</a>

			<div class="space-y-8">
				<div>
					<h1 class="font-bold text-4xl lg:text-5xl text-zinc-50 mb-4" style="font-family: var(--font-display)">{template.name}</h1>
					<div class="flex items-center gap-3 mb-4">
						<span class={`text-xs font-bold tracking-wider uppercase px-3 py-1 rounded border ${
							template.price === 'Free'
								? 'bg-gradient-to-r from-green-500/20 to-emerald-500/20 text-green-300 border-green-500/30'
								: 'bg-gradient-to-r from-amber-500/20 to-orange-500/20 text-amber-300 border-amber-500/30'
						}`}>
							{template.price}
						</span>
						<span class="text-zinc-400 text-sm">{template.category}</span>
					</div>
					<p class="text-zinc-300 text-lg leading-relaxed">{template.fullDesc}</p>
				</div>

				{template.image && (
					<div class="w-full rounded-xl overflow-hidden bg-zinc-900 border border-zinc-800 relative shadow-lg">
						<img src={template.image} alt={template.name} class="w-full h-auto block" />
					</div>
				)}

				<div class="flex items-center gap-4 pt-2">
					{template.price === 'Premium' ? (
						<>
							<a href={template.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-950 hover:text-black transition-colors bg-zinc-100 hover:bg-white px-6 py-3 rounded-lg shadow-sm font-semibold">
								Buy Template
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
							</a>
							<a href={template.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors px-6 py-3 rounded-lg font-semibold">
								Live Preview
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
							</a>
						</>
					) : (
						<>
							<a href={template.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-950 hover:text-black transition-colors bg-zinc-100 hover:bg-white px-6 py-3 rounded-lg shadow-sm font-semibold">
								Live Preview
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
							</a>
							<a href={template.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors px-6 py-3 rounded-lg font-semibold">
								Get Source Code
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
							</a>
						</>
					)}
				</div>

				<!-- Render Markdown Body Content -->
				<Content />

				<!-- Shared Dynamic Tech Stack -->
				<div class="space-y-4 pt-8">
					<h2 class="font-bold text-2xl text-zinc-200" style="font-family: var(--font-display)">Tech Stack</h2>
					<div class="flex flex-wrap gap-2">
						{template.tech.map(tech => (
							<span class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-zinc-900 text-zinc-300 border border-zinc-800">{tech}</span>
						))}
					</div>
				</div>
			</div>
		</div>
		<Analytics />
	</body>
</html>
