---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

const template = {
  name: "ProjectNG",
  status: "Active",
  category: "Workspace & Management",
  desc: "A premium, zoneless Angular 22+ dashboard template styled with Tailwind CSS v4. Features tasks, calendar, team view, inbox, and optimized animations.",
  fullDesc: "ProjectNG is a premium Angular 22+ dashboard template styled with Tailwind CSS v4. It features comprehensive task management, interactive calendar, team view, inbox system, and optimized animations. Built with zoneless change detection and signals for optimal performance. Perfect for workspace and management applications.",
  tech: ["Angular 22", "Tailwind v4", "Zoneless", "Signals"],
  github: "https://github.com/Likeur/draftng/tree/main/templates/projectng",
  demo: "https://projectng-three.vercel.app/dashboard",
  image: "/project/projectng.webp",
  date: "17 Jun 2026",
  price: "Free"
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>ProjectNG - Angular Workspace Dashboard Template | draftNG</title>
		
		<!-- SEO Meta Tags -->
		<link rel="canonical" href="https://draftng.com/projectng" />
		<meta name="description" content="ProjectNG - Free Angular 22+ workspace dashboard template with tasks, calendar, team view, inbox, and optimized animations. Zoneless, signals-based architecture with Tailwind CSS v4." />
		<meta name="keywords" content="Angular 22, workspace dashboard, project management, Tailwind CSS v4, Angular template, task manager, team collaboration" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://draftng.com/projectng" />
		<meta property="og:title" content="ProjectNG - Angular Workspace Dashboard Template | draftNG" />
		<meta property="og:description" content="Free Angular 22+ workspace dashboard template with tasks, calendar, team view, inbox, and optimized animations. Zoneless, signals-based architecture." />
		<meta property="og:image" content="https://draftng.com/draftOG.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://draftng.com/projectng" />
		<meta property="twitter:title" content="ProjectNG - Angular Workspace Dashboard Template | draftNG" />
		<meta property="twitter:description" content="Free Angular 22+ workspace dashboard template with tasks, calendar, team view, inbox, and optimized animations. Zoneless, signals-based architecture." />
		<meta property="twitter:image" content="https://draftng.com/draftOG.png" />

		<!-- Structured Data (JSON-LD) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "SoftwareApplication",
				"name": "ProjectNG",
				"operatingSystem": "Web",
				"applicationCategory": "BusinessApplication",
				"description": "A premium, zoneless Angular 22+ dashboard template styled with Tailwind CSS v4. Features tasks, calendar, team view, inbox, and optimized animations.",
				"offers": {
					"@type": "Offer",
					"price": "0",
					"priceCurrency": "USD"
				},
				"applicationSubCategory": "Project Management",
				"featureList": ["Task Management", "Interactive Calendar", "Team View", "Inbox System", "Optimized Animations"],
				"programmingLanguage": ["TypeScript", "Angular"],
				"author": {
					"@type": "Organization",
					"name": "draftNG",
					"url": "https://draftng.com"
				}
			}
		</script>
	</head>
	<body class="bg-zinc-950 text-zinc-100 selection:bg-zinc-100 selection:text-zinc-950 font-sans min-h-screen">
		<div class="max-w-4xl mx-auto px-6 py-12">
			<a href="/" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors mb-8">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
				Back to Templates
			</a>

			<div class="space-y-8">
				<div>
					<h1 class="font-display font-bold text-4xl lg:text-5xl text-zinc-50 mb-4">{template.name}</h1>
					<div class="flex items-center gap-3 mb-4">
						<span class="text-xs font-bold tracking-wider uppercase bg-gradient-to-r from-green-500/20 to-emerald-500/20 text-green-300 px-3 py-1 rounded border border-green-500/30">
							{template.price}
						</span>
						<span class="text-zinc-400 text-sm">{template.category}</span>
					</div>
					<p class="text-zinc-300 text-lg leading-relaxed">{template.fullDesc}</p>
				</div>

				{template.image && (
					<div class="w-full rounded-xl overflow-hidden bg-zinc-900 border border-zinc-800 relative shadow-lg">
						<img src={template.image} alt={template.name} class="w-full h-auto block" />
					</div>
				)}

				<div class="flex items-center gap-4 pt-2">
					<a href={template.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-950 hover:text-black transition-colors bg-zinc-100 hover:bg-white px-6 py-3 rounded-lg shadow-sm font-semibold">
						Live Preview
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</a>
					<a href={template.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors px-6 py-3 rounded-lg font-semibold">
						Get Source Code
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
					</a>
				</div>

				<div class="space-y-4">
					<h2 class="font-display font-bold text-2xl text-zinc-200">Features</h2>
					<ul class="space-y-2 text-zinc-400">
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Comprehensive task management
						</li>
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Interactive calendar
						</li>
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Team view and collaboration
						</li>
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Inbox system
						</li>
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Optimized animations
						</li>
					</ul>
				</div>

				<div class="space-y-4">
					<h2 class="font-display font-bold text-2xl text-zinc-200">Tech Stack</h2>
					<div class="flex flex-wrap gap-2">
						{template.tech.map(tech => (
							<span class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-zinc-900 text-zinc-300 border border-zinc-800">{tech}</span>
						))}
					</div>
				</div>
			</div>
		</div>
		<Analytics />
	</body>
</html>
