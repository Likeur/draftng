---
import '../styles/global.css';

const templates = [
  {
    name: "ProjectNG",
    status: "Active",
    category: "Workspace & Management",
    desc: "A premium, zoneless Angular 22+ dashboard template styled with Tailwind CSS v4. Features tasks, calendar, team view, inbox, and optimized animations.",
    tech: ["Angular 22", "Tailwind v4", "Zoneless", "Signals"],
    github: "https://github.com/Likeur/draftng/tree/main/templates/projectng",
    demo: "https://projectng-three.vercel.app/dashboard",
    video: "/project/projectng.webm",
    date: "17 Jun 2026"
  }
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>draftNG - Clean & Modern Angular 22+ Templates</title>
		<meta name="description" content="A curated collection of open-source, highly polished, and modern Angular templates styled with Tailwind CSS v4." />
	</head>
	<body class="bg-zinc-950 text-zinc-100 selection:bg-zinc-100 selection:text-zinc-950 font-sans min-h-screen lg:h-screen lg:overflow-hidden flex flex-col lg:flex-row relative">

		<!-- Left Column: Projects Display (50% Width, Independently Scrollable on Desktop, Horizontal Scroll on Mobile) -->
		<main class="w-full lg:w-1/2 h-auto lg:h-full lg:overflow-y-auto lg:scrollbar-none bg-zinc-950 flex flex-col justify-start">
			<div class="w-full max-w-2xl mx-auto px-6 sm:px-12 lg:pl-20 lg:pr-4 py-12 lg:py-24 flex flex-col gap-12">

				<div class="flex flex-row overflow-x-auto scrollbar-none gap-6 snap-x snap-mandatory -mx-6 px-6 sm:-mx-12 sm:px-12 lg:mx-0 lg:px-0 lg:flex-col lg:overflow-visible lg:gap-16 w-auto lg:w-full">
					{templates.map(tpl => (
						<div class="w-[85vw] sm:w-[450px] lg:w-full shrink-0 snap-start flex items-stretch gap-12 relative">
							<!-- Card Content: transparent background, no borders, no wrapper padding -->
							<div class="flex-grow flex flex-col justify-between min-h-[380px] group transition-all duration-500">
								<div>
									{tpl.video && (
										<div class="w-full h-48 sm:h-56 rounded-xl overflow-hidden mb-6 bg-zinc-950 border border-zinc-900/40 relative shadow-md">
											<video src={tpl.video} autoplay loop muted playsinline class="w-full h-full object-cover opacity-75 group-hover:opacity-95 transition-opacity duration-500"></video>
										</div>
									)}
									
									<h3 class="font-display font-bold text-2xl text-zinc-200 group-hover:text-white transition-colors mb-3">{tpl.name}</h3>
									<p class="text-zinc-400 text-sm leading-relaxed mb-6">{tpl.desc}</p>
								</div>

								<div class="space-y-5 pt-4">

									<div class="flex items-center gap-4 text-xs font-semibold">
										{tpl.demo && (
											<a href={tpl.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-zinc-950 hover:text-black transition-colors group/demo bg-zinc-100 hover:bg-white px-4 py-2 rounded-lg shadow-sm">
												Live Preview
												<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/demo:translate-x-0.5 group-hover/demo:-translate-y-0.5 transition-transform"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
											</a>
										)}
										<a href={tpl.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-zinc-400 hover:text-zinc-200 transition-colors group/link py-2">
											Get Source Code
											<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/link:translate-x-0.5 transition-transform"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
										</a>
									</div>
								</div>
							</div>

							<!-- Timeline Ruler (Vertical stacked ticks scrolling with the cards) -->
							<div class="hidden lg:flex w-16 shrink-0 relative items-center justify-end">
								<div class="absolute inset-y-0 right-0 flex flex-col items-end justify-between py-4 select-none pointer-events-none">
									{Array.from({ length: 28 }).map((_, idx) => {
										if (idx === 4) {
											return (
												<div class="flex items-center relative">
													<span class="text-[10px] font-bold text-zinc-400 font-display tracking-wider whitespace-nowrap absolute right-12">
														{tpl.date}
													</span>
													<span class="w-8 h-[1.5px] bg-zinc-200 block shrink-0"></span>
												</div>
											);
										}
										return <span class="w-3 h-[1px] bg-zinc-800 block shrink-0"></span>;
									})}
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</main>

		<!-- Mobile visual boundary separator -->
		<div class="block lg:hidden h-[1px] bg-zinc-900 w-full shrink-0"></div>

		<!-- Right Column: Platform Information (50% Width, Sticky/Fixed, Non-scrollable) -->
		<aside class="w-full lg:w-1/2 h-auto lg:h-full flex flex-col justify-between gap-12 p-8 sm:p-12 lg:p-24 relative overflow-hidden bg-zinc-950 shrink-0 lg:sticky lg:top-0">
			<!-- Background grid *only* on the right side -->
			<div class="absolute inset-0 bg-[linear-gradient(to_right,#18181b40_1px,transparent_1px),linear-gradient(to_bottom,#18181b40_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] pointer-events-none -z-10"></div>
			<div class="absolute top-[20vh] right-[10%] w-[350px] h-[350px] bg-zinc-900/10 rounded-full blur-[130px] pointer-events-none -z-10"></div>

			<div class="space-y-6">
				<div class="flex items-center gap-3">
					<div class="w-8 h-8 rounded bg-zinc-100 flex items-center justify-center font-display font-extrabold text-zinc-950 text-base shadow-md">
						d
					</div>
					<span class="font-display font-bold text-3xl tracking-tighter text-zinc-50">draftNG</span>
				</div>
				
				<div class="space-y-4">
					<p class="font-display font-medium text-xl lg:text-2xl text-zinc-200 leading-tight">
						Minimalist & high-performance Angular 22+ templates.
					</p>
					<p class="text-zinc-400 text-sm leading-relaxed">
						A curated suite of open-source platform templates styled with Tailwind CSS v4. Engineered to elevate your Angular development workflow with zoneless change detection, clean state paradigms, and interactive interfaces.
					</p>
					<div class="pt-2">
						<a href="https://github.com/Likeur/draftng/tree/main" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-950 hover:text-black transition-colors bg-zinc-100 hover:bg-white px-4 py-2.5 rounded-lg shadow-sm font-semibold text-xs">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
							See on GitHub
						</a>
					</div>
				</div>
			</div>

			<div class="space-y-6">
				<div class="space-y-4">
					<span class="text-xs font-medium text-zinc-500 tracking-wide">built by likeur</span>
					<div class="flex gap-4">
						<!-- LinkedIn -->
						<a href="https://www.linkedin.com/in/likeur/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-11 h-11 rounded-full bg-zinc-900/20 hover:bg-zinc-900 flex items-center justify-center text-zinc-400 hover:text-white transition-all duration-300 hover:scale-105 shadow-sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
						</a>
						
						<!-- X (Twitter) -->
						<a href="https://x.com/likeurrr" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="w-11 h-11 rounded-full bg-zinc-900/20 hover:bg-zinc-900 flex items-center justify-center text-zinc-400 hover:text-white transition-all duration-300 hover:scale-105 shadow-sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						</a>

						<!-- GitHub -->
						<a href="https://github.com/Likeur" target="_blank" rel="noopener noreferrer" aria-label="GitHub Profile" class="w-11 h-11 rounded-full bg-zinc-900/20 hover:bg-zinc-900 flex items-center justify-center text-zinc-400 hover:text-white transition-all duration-300 hover:scale-105 shadow-sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
						</a>
					</div>
				</div>
				
			</div>
		</aside>

	</body>
</html>
