---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

const templates = [
  {
    name: "KleenTrack",
    status: "Active",
    category: "Finance & Budgeting",
    desc: "A premium, high-performance Angular 22+ finance tracking dashboard template. Features interactive budgeting tools, transaction histories, accounts management, invoice generators, and optimized charts.",
    tech: ["Angular 22", "Tailwind v4", "Finance Tracker", "Charts"],
    github: "https://store.draftng.xyz/prd_zt5vvy7t",
    demo: "https://kleen-track.vercel.app/overview",
    image: "/project/kleenTrack.webp",
    date: "10 Jun 2026",
    slug: "kleentrack"
  },
  {
    name: "ProjectNG",
    status: "Active",
    category: "Workspace & Management",
    desc: "A premium, zoneless Angular 22+ dashboard template styled with Tailwind CSS v4. Features tasks, calendar, team view, inbox, and optimized animations.",
    tech: ["Angular 22", "Tailwind v4", "Zoneless", "Signals"],
    github: "https://github.com/Likeur/draftng/tree/main/templates/projectng",
    demo: "https://projectng-three.vercel.app/dashboard",
    image: "/project/projectng.webp",
    date: "17 Jun 2026",
    slug: "projectng"
  },
  {
    name: "Jordy AI",
    status: "Active",
    category: "AI Chatbot & Platform",
    desc: "A premium, modern AI chatbot platform template (similar to Gemini or Perplexity). Fully built with Angular 22 and Tailwind CSS v4, featuring integrated AI image generation, video generation, code generation, and a personal library.",
    tech: ["Angular 22", "Tailwind v4", "AI Chatbot", "Multi-modal"],
    github: "https://store.draftng.xyz/prd_ztd707zu",
    demo: "https://jordyai.vercel.app/chat",
    image: "/project/jordyai.webp",
    date: "19 Jun 2026",
    slug: "jordyai"
  }
];

const totalCount = templates.length;
const freeCount = templates.filter(t => t.github && t.github.includes('github.com')).length;
const premiumCount = templates.filter(t => !t.github || !t.github.includes('github.com')).length;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>draftNG - Clean & Modern Angular 22+ Templates</title>
		
		<!-- SEO Meta Tags -->
		<link rel="canonical" href="https://draftng.com/" />
		<meta name="description" content="Download premium Angular 22+ templates with Tailwind CSS v4. Free & paid dashboard templates including finance trackers, project management, and AI chatbot platforms. Zoneless, signals-based architecture." />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://draftng.com/" />
		<meta property="og:title" content="draftNG - Clean & Modern Angular 22+ Templates" />
		<meta property="og:description" content="Download premium Angular 22+ templates with Tailwind CSS v4. Free & paid dashboard templates including finance trackers, project management, and AI chatbot platforms. Zoneless, signals-based architecture." />
		<meta property="og:image" content="https://draftng.com/draftOG.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://draftng.com/" />
		<meta property="twitter:title" content="draftNG - Clean & Modern Angular 22+ Templates" />
		<meta property="twitter:description" content="Download premium Angular 22+ templates with Tailwind CSS v4. Free & paid dashboard templates including finance trackers, project management, and AI chatbot platforms. Zoneless, signals-based architecture." />
		<meta property="twitter:image" content="https://draftng.com/draftOG.png" />

		<!-- Structured Data (JSON-LD) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "SoftwareApplication",
				"name": "draftNG",
				"operatingSystem": "Web",
				"applicationCategory": "DeveloperApplication",
				"description": "Download premium Angular 22+ templates with Tailwind CSS v4. Free & paid dashboard templates including finance trackers, project management, and AI chatbot platforms. Zoneless, signals-based architecture.",
				"offers": {
					"@type": "AggregateOffer",
					"priceCurrency": "USD",
					"lowPrice": "0",
					"offerCount": "3"
				},
				"aggregateRating": {
					"@type": "AggregateRating",
					"ratingValue": "4.8",
					"ratingCount": "42"
				}
			}
		</script>

		<!-- Organization Schema -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "draftNG",
				"url": "https://draftng.com",
				"logo": "https://draftng.com/favicon.svg",
				"description": "A curated collection of open-source, highly polished, and modern Angular templates styled with Tailwind CSS v4.",
				"sameAs": [
					"https://github.com/Likeur/draftng",
					"https://x.com/likeurrr",
					"https://linkedin.com/in/likeur"
				]
			}
		</script>
	</head>
	<body class="bg-zinc-950 text-zinc-100 selection:bg-zinc-100 selection:text-zinc-950 font-sans min-h-screen lg:h-screen lg:overflow-hidden flex flex-col lg:flex-row relative">

		<!-- Left Column: Projects Display (50% Width, Independently Scrollable on Desktop, Horizontal Scroll on Mobile) -->
		<main class="w-full lg:w-1/2 h-auto lg:h-full lg:overflow-y-auto lg:scrollbar-none bg-zinc-950 flex flex-col justify-start">
			<div class="w-full max-w-2xl mx-auto px-6 sm:px-12 lg:pl-20 lg:pr-4 py-12 lg:py-24 flex flex-col gap-8">

				<!-- Filter Bubbles -->
				<div class="flex items-center gap-2 flex-wrap -mx-6 px-6 sm:-mx-12 sm:px-12 lg:mx-0 lg:px-0">
					<button data-filter="all" class="filter-btn text-xs font-semibold px-4 py-2 rounded-full transition-all duration-300 bg-zinc-100 text-zinc-950 border border-transparent shadow-sm cursor-pointer select-none">
						All ({totalCount})
					</button>
					<button data-filter="free" class="filter-btn text-xs font-semibold px-4 py-2 rounded-full transition-all duration-300 bg-zinc-900/40 text-zinc-400 border border-zinc-900 hover:bg-zinc-900 hover:text-zinc-200 cursor-pointer select-none">
						Free ({freeCount})
					</button>
					<button data-filter="premium" class="filter-btn text-xs font-semibold px-4 py-2 rounded-full transition-all duration-300 bg-zinc-900/40 text-zinc-400 border border-zinc-900 hover:bg-zinc-900 hover:text-zinc-200 cursor-pointer select-none">
						Premium ({premiumCount})
					</button>
				</div>

				<h2 class="sr-only">Available Templates</h2>

				<div class="flex flex-row overflow-x-auto scrollbar-none gap-6 snap-x snap-mandatory -mx-6 px-6 sm:-mx-12 sm:px-12 lg:mx-0 lg:px-0 lg:flex-col lg:overflow-visible lg:gap-16 w-auto lg:w-full">
					{templates.map(tpl => (
						<div class="project-card w-[85vw] sm:w-[450px] lg:w-full shrink-0 snap-start flex items-stretch gap-12 relative transition-all duration-300" data-type={tpl.github && tpl.github.includes('github.com') ? 'free' : 'premium'}>
							<!-- Card Content: transparent background, no borders, no wrapper padding -->
							<div class="flex-grow flex flex-col justify-between min-h-[380px] group transition-all duration-500">
								<div>
									{tpl.image && (
										<div class="w-full rounded-xl overflow-hidden mb-6 bg-zinc-950 border border-zinc-900/40 relative shadow-md">
											<img src={tpl.image} alt={tpl.name} class="w-full h-auto block opacity-75 group-hover:opacity-95 transition-opacity duration-500" />
										</div>
									)}
									<div class="flex items-center gap-3 mb-3">
										<a href={`/${tpl.slug}`} class="font-bold text-2xl text-zinc-200 group-hover:text-white transition-colors hover:underline" style="font-family: var(--font-display)">{tpl.name}</a>
										{(!tpl.github || !tpl.github.includes('github.com')) && (
											<span class="text-[10px] font-bold tracking-wider uppercase bg-gradient-to-r from-amber-500/20 to-orange-500/20 text-amber-300 px-2 py-0.5 rounded border border-amber-500/30">
												Premium
											</span>
										)}
									</div>
									<p class="text-zinc-400 text-sm leading-relaxed mb-6">{tpl.desc}</p>
								</div>

								<div class="space-y-5 pt-4">

									<div class="flex items-center gap-4 text-xs font-semibold">
										{tpl.github && !tpl.github.includes('github.com') ? (
											<>
												<a href={tpl.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-zinc-950 hover:text-black transition-colors group/demo bg-zinc-100 hover:bg-white px-4 py-2 rounded-lg shadow-sm">
													Buy Template
													<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/demo:translate-x-0.5 group-hover/demo:-translate-y-0.5 transition-transform"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
												</a>
												{tpl.demo && (
													<a href={tpl.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-zinc-400 hover:text-zinc-200 transition-colors group/link py-2">
														Live Preview
														<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/link:translate-x-0.5 transition-transform"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
													</a>
												)}
											</>
										) : (
											<>
												{tpl.demo && (
													<a href={tpl.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-zinc-950 hover:text-black transition-colors group/demo bg-zinc-100 hover:bg-white px-4 py-2 rounded-lg shadow-sm">
														Live Preview
														<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/demo:translate-x-0.5 group-hover/demo:-translate-y-0.5 transition-transform"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
													</a>
												)}
												{tpl.github && (
													<a href={tpl.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-zinc-400 hover:text-zinc-200 transition-colors group/link py-2">
														Get Source Code
														<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/link:translate-x-0.5 transition-transform"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
													</a>
												)}
											</>
										)}
									</div>
								</div>
							</div>

							<!-- Timeline Ruler (Vertical stacked ticks scrolling with the cards) -->
							<div class="hidden lg:flex w-16 shrink-0 relative items-center justify-end">
								<div class="absolute inset-y-0 right-0 flex flex-col items-end justify-between py-4 select-none pointer-events-none">
									{Array.from({ length: 28 }).map((_, idx) => {
										if (idx === 4) {
											return (
												<div class="flex items-center relative">
													<span class="text-[10px] font-bold text-zinc-400 tracking-wider whitespace-nowrap absolute right-12" style="font-family: var(--font-display)">
														{tpl.date}
													</span>
													<span class="w-8 h-[1.5px] bg-zinc-200 block shrink-0"></span>
												</div>
											);
										}
										return <span class="w-3 h-[1px] bg-zinc-800 block shrink-0"></span>;
									})}
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</main>

		<!-- Mobile visual boundary separator -->
		<div class="block lg:hidden h-[1px] bg-zinc-900 w-full shrink-0"></div>

		<!-- Right Column: Platform Information (50% Width, Sticky/Fixed, Non-scrollable) -->
		<aside class="w-full lg:w-1/2 h-auto lg:h-full flex flex-col justify-between gap-12 p-8 sm:p-12 lg:p-24 relative overflow-hidden bg-zinc-950 shrink-0 lg:sticky lg:top-0">
			<!-- God Rays Canvas (Desktop only) -->
			<div class="hidden lg:block absolute inset-0 pointer-events-none -z-20 overflow-hidden">
				<canvas id="god-rays-canvas" class="w-full h-full opacity-35"></canvas>
			</div>
			<!-- Background grid *only* on the right side -->
			<div class="absolute inset-0 bg-[linear-gradient(to_right,#18181b40_1px,transparent_1px),linear-gradient(to_bottom,#18181b40_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] pointer-events-none -z-10"></div>
			<div class="absolute top-[20vh] right-[10%] w-[350px] h-[350px] bg-zinc-900/10 rounded-full blur-[130px] pointer-events-none -z-10"></div>

			<div class="space-y-6">
				<div class="flex items-center gap-3">
					<div class="w-8 h-8 rounded bg-zinc-100 flex items-center justify-center font-extrabold text-zinc-950 text-base shadow-md" style="font-family: var(--font-display)">
						d
					</div>
					<h1 class="font-bold text-3xl tracking-tighter text-zinc-50" style="font-family: var(--font-display)">draftNG</h1>
				</div>
				
				<div class="space-y-4">
					<p class="font-medium text-xl lg:text-2xl text-zinc-200 leading-tight" style="font-family: var(--font-display)">
						Minimalist & high-performance Angular 22+ platform templates.
					</p>
					<p class="text-zinc-400 text-sm leading-relaxed">
						A curated suite of open-source platform templates styled with Tailwind CSS v4. Engineered to elevate your Angular development workflow with zoneless change detection, clean state paradigms, and interactive interfaces.
					</p>
					<div class="pt-2">
						<a href="https://github.com/Likeur/draftng/tree/main" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-950 hover:text-black transition-colors bg-zinc-100 hover:bg-white px-4 py-2.5 rounded-lg shadow-sm font-semibold text-xs">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
							See on GitHub
						</a>
						<a href="/blog" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors px-4 py-2.5 rounded-lg font-semibold text-xs ml-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
							Blog
						</a>
					</div>
				</div>
			</div>

			<div class="space-y-6">
				<div class="space-y-5">
					<span class="text-sm text-zinc-500 font-sans tracking-wide">built by likeur</span>
					<div class="flex gap-4">
						<!-- LinkedIn -->
						<a href="https://www.linkedin.com/in/likeur/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-11 h-11 rounded-full bg-zinc-900/20 hover:bg-zinc-900 flex items-center justify-center text-zinc-400 hover:text-white transition-all duration-300 hover:scale-105 shadow-sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
						</a>
						
						<!-- X (Twitter) -->
						<a href="https://x.com/likeurrr" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="w-11 h-11 rounded-full bg-zinc-900/20 hover:bg-zinc-900 flex items-center justify-center text-zinc-400 hover:text-white transition-all duration-300 hover:scale-105 shadow-sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						</a>

						<!-- GitHub -->
						<a href="https://github.com/Likeur" target="_blank" rel="noopener noreferrer" aria-label="GitHub Profile" class="w-11 h-11 rounded-full bg-zinc-900/20 hover:bg-zinc-900 flex items-center justify-center text-zinc-400 hover:text-white transition-all duration-300 hover:scale-105 shadow-sm">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
						</a>
					</div>
			</div>
		</aside>

		<script>
			const filterBtns = document.querySelectorAll('.filter-btn');
			const projectCards = document.querySelectorAll('.project-card');

			filterBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					const filter = btn.getAttribute('data-filter');

					// Update buttons active/inactive states
					filterBtns.forEach(b => {
						if (b === btn) {
							b.classList.remove('bg-zinc-900/40', 'text-zinc-400', 'border-zinc-900', 'hover:bg-zinc-900', 'hover:text-zinc-200');
							b.classList.add('bg-zinc-100', 'text-zinc-950', 'border-transparent');
						} else {
							b.classList.remove('bg-zinc-100', 'text-zinc-950', 'border-transparent');
							b.classList.add('bg-zinc-900/40', 'text-zinc-400', 'border-zinc-900', 'hover:bg-zinc-900', 'hover:text-zinc-200');
						}
					});

					// Filter card visibility
					projectCards.forEach(card => {
						const cardType = card.getAttribute('data-type');
						if (filter === 'all' || cardType === filter) {
							card.classList.remove('hidden');
						} else {
							card.classList.add('hidden');
						}
					});
				});
			});

			// Allow scrolling main projects container from anywhere on the window on desktop
			window.addEventListener('wheel', (e) => {
				if (window.innerWidth >= 1024) {
					const projectsContainer = document.querySelector('main');
					const rightColumn = document.querySelector('aside');
					if (projectsContainer && rightColumn && e.target instanceof Node && rightColumn.contains(e.target)) {
						projectsContainer.scrollTop += e.deltaY;
					}
				}
			}, { passive: true });

			// God Rays Texture Shader Canvas animation (Desktop only)
			const canvas = document.getElementById('god-rays-canvas');
			if (canvas instanceof HTMLCanvasElement) {
				const ctx = canvas.getContext('2d');
				let width = canvas.offsetWidth;
				let height = canvas.offsetHeight;
				canvas.width = width;
				canvas.height = height;

				window.addEventListener('resize', () => {
					if (canvas) {
						width = canvas.offsetWidth;
						height = canvas.offsetHeight;
						canvas.width = width;
						canvas.height = height;
					}
				});

				const raysCount = 10;
				const rays: { angleOffset: number; speed: number; width: number; baseOpacity: number }[] = [];
				for (let i = 0; i < raysCount; i++) {
					rays.push({
						angleOffset: Math.random() * Math.PI * 2,
						speed: 0.0005 + Math.random() * 0.001,
						width: 0.08 + Math.random() * 0.15,
						baseOpacity: 0.04 + Math.random() * 0.08
					});
				}

				function animate(time: number) {
					if (!ctx || !canvas) return;
					ctx.clearRect(0, 0, width, height);

					const originX = width;
					const originY = 0;
					const maxRadius = Math.sqrt(width * width + height * height);

					// Draw a subtle radial glow in the corner
					const glowGrad = ctx.createRadialGradient(originX, originY, 0, originX, originY, maxRadius * 0.7);
					glowGrad.addColorStop(0, 'rgba(255, 255, 255, 0.05)');
					glowGrad.addColorStop(0.5, 'rgba(255, 255, 255, 0.01)');
					glowGrad.addColorStop(1, 'rgba(0, 0, 0, 0)');
					ctx.fillStyle = glowGrad;
					ctx.fillRect(0, 0, width, height);

					// Draw the rays
					rays.forEach(ray => {
						const angle = (Math.PI * 0.75) + Math.sin(time * ray.speed + ray.angleOffset) * 0.15;
						const halfWidth = ray.width / 2;

						ctx.beginPath();
						ctx.moveTo(originX, originY);

						const startAngle = angle - halfWidth;
						const endAngle = angle + halfWidth;

						const x1 = originX + Math.cos(startAngle) * maxRadius;
						const y1 = originY + Math.sin(startAngle) * maxRadius;
						const x2 = originX + Math.cos(endAngle) * maxRadius;
						const y2 = originY + Math.sin(endAngle) * maxRadius;

						ctx.lineTo(x1, y1);
						ctx.lineTo(x2, y2);
						ctx.closePath();

						const rayGrad = ctx.createRadialGradient(originX, originY, 0, originX, originY, maxRadius);
						const currentOpacity = ray.baseOpacity * (0.8 + Math.sin(time * 0.002 + ray.angleOffset) * 0.2);
						rayGrad.addColorStop(0, `rgba(255, 255, 255, ${currentOpacity})`);
						rayGrad.addColorStop(0.5, `rgba(255, 255, 255, ${currentOpacity * 0.3})`);
						rayGrad.addColorStop(1, 'rgba(255, 255, 255, 0)');

						ctx.fillStyle = rayGrad;
						ctx.fill();
					});

					requestAnimationFrame(animate);
				}
				requestAnimationFrame(animate);
			}
		</script>

		<Analytics />
	</body>
</html>
