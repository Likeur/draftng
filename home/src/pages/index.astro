---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>draftNG - Clean & Modern Angular 22+ Templates</title>
		<meta name="description" content="A curated collection of open-source, highly polished, and modern Angular templates styled with Tailwind CSS v4." />
	</head>
	<body class="bg-brand-950 text-brand-50 selection:bg-brand-500 selection:text-brand-950 font-sans min-h-screen flex flex-col relative">
		<!-- Background Glows -->
		<div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-brand-500/10 rounded-full blur-[120px] pointer-events-none -z-10"></div>
		<div class="absolute top-[30vh] right-1/4 w-[600px] h-[600px] bg-accent-500/5 rounded-full blur-[150px] pointer-events-none -z-10"></div>

		<!-- Navigation Header -->
		<header class="sticky top-0 z-50 backdrop-blur-md bg-brand-950/70 border-b border-brand-900/50 transition-all duration-300">
			<div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-brand-600 to-accent-500 flex items-center justify-center font-display font-extrabold text-brand-950 text-lg shadow-lg shadow-brand-500/10">
						dNG
					</div>
					<span class="font-display font-bold text-xl tracking-tight bg-gradient-to-r from-brand-50 to-brand-300 bg-clip-text text-transparent">draftNG</span>
				</div>
				<nav class="hidden md:flex items-center gap-8 text-sm font-medium text-brand-300">
					<a href="#features" class="hover:text-brand-50 transition-colors">Features</a>
					<a href="#templates" class="hover:text-brand-50 transition-colors">Templates</a>
					<a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hover:text-brand-50 transition-colors flex items-center gap-2">
						GitHub
					</a>
				</nav>
				<div>
					<a href="#templates" class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl bg-brand-500 hover:bg-brand-400 text-brand-950 font-semibold text-sm transition-all duration-300 shadow-md shadow-brand-500/15 hover:shadow-brand-500/25 hover:-translate-y-0.5">
						Browse Library
					</a>
				</div>
			</div>
		</header>

		<main class="flex-grow">
			<!-- Hero Section -->
			<section class="max-w-7xl mx-auto px-6 pt-24 pb-20 text-center relative">
				<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-900/40 border border-brand-800/60 mb-6 backdrop-blur-sm">
					<span class="w-2 h-2 rounded-full bg-accent-500 animate-pulse"></span>
					<span class="text-xs font-semibold tracking-wider uppercase text-brand-300">Open Source Ecosystem</span>
				</div>
				
				<h1 class="font-display font-extrabold text-5xl md:text-7xl leading-tight max-w-4xl mx-auto mb-8">
					Clean Angular Templates for 
					<span class="bg-gradient-to-r from-brand-300 via-brand-100 to-accent-400 bg-clip-text text-transparent">Modern Creators</span>
				</h1>
				
				<p class="text-brand-300 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed mb-12">
					A curated suite of beautiful, production-ready, open-source dashboard and application templates. Built with Angular 22 and Tailwind CSS v4 using modern best practices.
				</p>
				
				<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
					<a href="#templates" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 rounded-xl bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-400 text-brand-50 font-bold text-base transition-all duration-300 shadow-lg shadow-brand-600/20 hover:shadow-brand-600/35 hover:-translate-y-0.5">
						Explore Templates
					</a>
					<a href="https://github.com" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 rounded-xl bg-brand-900/30 hover:bg-brand-900/60 border border-brand-800/60 hover:border-brand-700 text-brand-300 hover:text-brand-50 font-bold text-base transition-all duration-300 backdrop-blur-sm">
						View on GitHub
					</a>
				</div>
			</section>

			<!-- Features Section -->
			<section id="features" class="max-w-7xl mx-auto px-6 py-20 border-t border-brand-900/40">
				<div class="text-center mb-16">
					<h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Why draftNG?</h2>
					<p class="text-brand-300 max-w-lg mx-auto">Engineered to elevate your Angular development workflow with modern standards.</p>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<!-- Card 1 -->
					<div class="p-8 rounded-2xl bg-brand-900/20 border border-brand-900/60 hover:border-brand-800/80 transition-all duration-300 group hover:-translate-y-1">
						<div class="w-12 h-12 rounded-xl bg-brand-500/10 border border-brand-500/20 flex items-center justify-center mb-6 group-hover:bg-brand-500/20 transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
							</svg>
						</div>
						<h3 class="font-display font-semibold text-xl mb-3">Modern Angular 22+</h3>
						<p class="text-brand-300 text-sm leading-relaxed">
							Leveraging cutting-edge features: standalone APIs, Signals, zoneless change detection, and optimized server-side rendering (SSR).
						</p>
					</div>

					<!-- Card 2 -->
					<div class="p-8 rounded-2xl bg-brand-900/20 border border-brand-900/60 hover:border-brand-800/80 transition-all duration-300 group hover:-translate-y-1">
						<div class="w-12 h-12 rounded-xl bg-brand-500/10 border border-brand-500/20 flex items-center justify-center mb-6 group-hover:bg-brand-500/20 transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4zM14 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2v-4z" />
							</svg>
						</div>
						<h3 class="font-display font-semibold text-xl mb-3">Tailwind CSS v4</h3>
						<p class="text-brand-300 text-sm leading-relaxed">
							Utilizing CSS-first variables, ultra-fast builds, container queries, and native custom animations directly out of the box.
						</p>
					</div>

					<!-- Card 3 -->
					<div class="p-8 rounded-2xl bg-brand-900/20 border border-brand-900/60 hover:border-brand-800/80 transition-all duration-300 group hover:-translate-y-1">
						<div class="w-12 h-12 rounded-xl bg-brand-500/10 border border-brand-500/20 flex items-center justify-center mb-6 group-hover:bg-brand-500/20 transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 009 11V7a4 4 0 00-8 0v4c0 2.876-.906 5.565-2.448 7.794m16.082-9.45a13.904 13.904 0 012.248 7.794V17a3 3 0 01-3 3h-2M13.616 5.34a3.997 3.997 0 013.766 3.65m-3.766-3.65L19.5 3.375" />
							</svg>
						</div>
						<h3 class="font-display font-semibold text-xl mb-3">Developer Centric</h3>
						<p class="text-brand-300 text-sm leading-relaxed">
							Thoroughly organized components, scalable state patterns, robust typescript typings, and strict mode compliance.
						</p>
					</div>
				</div>
			</section>

			<!-- Showcase Section -->
			<section id="templates" class="max-w-7xl mx-auto px-6 py-20 border-t border-brand-900/40">
				<div class="text-center mb-16">
					<h2 class="font-display font-bold text-3xl md:text-4xl mb-4">Premium Templates Catalogue</h2>
					<p class="text-brand-300 max-w-lg mx-auto">Explore our collection of open-source platform templates built for Angular developers.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<!-- Template Card 1 -->
					<div class="relative overflow-hidden rounded-2xl bg-brand-900/20 border border-brand-900/60 hover:border-brand-800/80 transition-all duration-500 group flex flex-col justify-between min-h-[350px]">
						<div class="absolute top-4 right-4 z-10">
							<span class="px-3 py-1 text-xs font-bold tracking-wider uppercase bg-accent-500/10 text-accent-400 border border-accent-500/30 rounded-full">Coming Soon</span>
						</div>
						<div class="p-8">
							<span class="text-xs font-semibold text-brand-400 tracking-widest uppercase block mb-2">Workspace & Operations</span>
							<h3 class="font-display font-bold text-2xl mb-4 group-hover:text-brand-300 transition-colors">Vanguard Dashboard</h3>
							<p class="text-brand-300 text-sm leading-relaxed max-w-md">
								A comprehensive admin and metrics dashboard. Featuring complex charting, responsive sidebar navigation, advanced filter tables, and real-time state.
							</p>
						</div>
						<div class="px-8 py-5 border-t border-brand-900/60 bg-brand-950/40 flex items-center justify-between mt-auto">
							<span class="text-xs text-brand-400 font-medium">Angular 22 + Tailwind v4</span>
							<span class="text-brand-300 text-xs flex items-center gap-1">
								Under construction
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
								</svg>
							</span>
						</div>
					</div>

					<!-- Template Card 2 -->
					<div class="relative overflow-hidden rounded-2xl bg-brand-900/20 border border-brand-900/60 hover:border-brand-800/80 transition-all duration-500 group flex flex-col justify-between min-h-[350px]">
						<div class="absolute top-4 right-4 z-10">
							<span class="px-3 py-1 text-xs font-bold tracking-wider uppercase bg-accent-500/10 text-accent-400 border border-accent-500/30 rounded-full">Coming Soon</span>
						</div>
						<div class="p-8">
							<span class="text-xs font-semibold text-brand-400 tracking-widest uppercase block mb-2">Commerce Platform</span>
							<h3 class="font-display font-bold text-2xl mb-4 group-hover:text-brand-300 transition-colors">Aether E-Commerce</h3>
							<p class="text-brand-300 text-sm leading-relaxed max-w-md">
								A dynamic storefront template. Designed for conversion with modern gallery layouts, seamless cart states, beautiful product filters, and checkouts.
							</p>
						</div>
						<div class="px-8 py-5 border-t border-brand-900/60 bg-brand-950/40 flex items-center justify-between mt-auto">
							<span class="text-xs text-brand-400 font-medium">Angular 22 + Tailwind v4</span>
							<span class="text-brand-300 text-xs flex items-center gap-1">
								Under construction
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
								</svg>
							</span>
						</div>
					</div>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="border-t border-brand-900/60 bg-brand-950 py-12 text-sm text-brand-400">
			<div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
				<div class="flex items-center gap-2">
					<div class="w-6 h-6 rounded-md bg-gradient-to-tr from-brand-600 to-accent-500 flex items-center justify-center font-display font-extrabold text-brand-950 text-xs">
						d
					</div>
					<span class="font-display font-semibold text-brand-300">draftNG</span>
				</div>
				<p>© 2026 draftNG. Built with Astro & Tailwind CSS v4. Released under MIT License.</p>
				<div class="flex gap-6">
					<a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hover:text-brand-50 transition-colors">GitHub</a>
					<a href="https://angular.dev" target="_blank" rel="noopener noreferrer" class="hover:text-brand-50 transition-colors">Angular.dev</a>
				</div>
			</div>
		</footer>
	</body>
</html>
