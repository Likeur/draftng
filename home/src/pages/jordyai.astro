---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

const template = {
  name: "Jordy AI",
  status: "Active",
  category: "AI Chatbot & Platform",
  desc: "An elegant, publication-grade AI Dashboard Template designed for modern conversational interfaces, code playgrounds, image generation grids, and video production workspaces. Built on Angular 22 and Tailwind CSS v4.",
  fullDesc: "JordyAI is an elegant, publication-grade AI Dashboard Template designed for modern conversational interfaces, code playgrounds, image generation grids, and video production workspaces. Built on the cutting-edge foundations of Angular 22 and Tailwind CSS v4.0, it offers a state-of-the-art developer experience and a premium aesthetic that will instantly elevate your product.",
  tech: ["Angular 22", "Tailwind v4", "AI Chatbot", "Multi-modal"],
  github: "https://store.draftng.xyz/prd_ztd707zu",
  demo: "https://jordyai.vercel.app/chat",
  image: "/project/jordyai.webp",
  date: "19 Jun 2026",
  price: "Premium"
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Jordy AI - Angular AI Chatbot Platform Template | draftNG</title>
		
		<!-- SEO Meta Tags -->
		<link rel="canonical" href="https://draftng.com/jordyai" />
		<meta name="description" content="Jordy AI - Premium Angular 22+ AI chatbot platform template with image generation, video generation, code generation, and personal library. Multi-modal AI with Tailwind CSS v4." />
		<meta name="keywords" content="Angular 22, AI chatbot, AI platform, Tailwind CSS v4, Angular template, multi-modal AI, image generation, code generation" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://draftng.com/jordyai" />
		<meta property="og:title" content="Jordy AI - Angular AI Chatbot Platform Template | draftNG" />
		<meta property="og:description" content="Premium Angular 22+ AI chatbot platform template with image generation, video generation, code generation, and personal library. Multi-modal AI." />
		<meta property="og:image" content="https://draftng.com/draftOG.png" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://draftng.com/jordyai" />
		<meta property="twitter:title" content="Jordy AI - Angular AI Chatbot Platform Template | draftNG" />
		<meta property="twitter:description" content="Premium Angular 22+ AI chatbot platform template with image generation, video generation, code generation, and personal library. Multi-modal AI." />
		<meta property="twitter:image" content="https://draftng.com/draftOG.png" />

		<!-- Structured Data (JSON-LD) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "SoftwareApplication",
				"name": "Jordy AI",
				"operatingSystem": "Web",
				"applicationCategory": "AIApplication",
				"description": "A premium, modern AI chatbot platform template (similar to Gemini or Perplexity). Fully built with Angular 22 and Tailwind CSS v4, featuring integrated AI image generation, video generation, code generation, and a personal library.",
				"offers": {
					"@type": "Offer",
					"priceCurrency": "USD",
					"availability": "https://schema.org/InStock"
				},
				"applicationSubCategory": "AI Chatbot Platform",
				"featureList": ["AI Image Generation", "AI Video Generation", "Code Generation", "Personal Library", "Multi-modal AI"],
				"programmingLanguage": ["TypeScript", "Angular"],
				"author": {
					"@type": "Organization",
					"name": "draftNG",
					"url": "https://draftng.com"
				}
			}
		</script>
	</head>
	<body class="bg-zinc-950 text-zinc-100 selection:bg-zinc-100 selection:text-zinc-950 font-sans min-h-screen">
		<div class="max-w-4xl mx-auto px-6 py-12">
			<a href="/" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors mb-8">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
				Back to Templates
			</a>

			<div class="space-y-8">
				<div>
					<h1 class="font-bold text-4xl lg:text-5xl text-zinc-50 mb-4" style="font-family: var(--font-display)">{template.name}</h1>
					<div class="flex items-center gap-3 mb-4">
						<span class="text-xs font-bold tracking-wider uppercase bg-gradient-to-r from-amber-500/20 to-orange-500/20 text-amber-300 px-3 py-1 rounded border border-amber-500/30">
							{template.price}
						</span>
						<span class="text-zinc-400 text-sm">{template.category}</span>
					</div>
					<p class="text-zinc-300 text-lg leading-relaxed">{template.fullDesc}</p>
				</div>

				{template.image && (
					<div class="w-full rounded-xl overflow-hidden bg-zinc-900 border border-zinc-800 relative shadow-lg">
						<img src={template.image} alt={template.name} class="w-full h-auto block" />
					</div>
				)}

				<div class="flex items-center gap-4 pt-2">
					<a href={template.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-950 hover:text-black transition-colors bg-zinc-100 hover:bg-white px-6 py-3 rounded-lg shadow-sm font-semibold">
						Buy Template
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
					</a>
					<a href={template.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition-colors px-6 py-3 rounded-lg font-semibold">
						Live Preview
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
					</a>
				</div>

				<div class="space-y-4">
					<h2 class="font-bold text-2xl text-zinc-200" style="font-family: var(--font-display)">Key Features</h2>
					<ul class="space-y-3 text-zinc-400">
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Bleeding-Edge Tech Stack:</strong> Angular 22 standalone architecture with fine-grained Signals for reactive, ultra-fast performance, paired with Tailwind CSS v4's high-speed Oxide compiler.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Premium Editorial Aesthetics:</strong> Elegant combination of publication-style typography (Lora serif & Plus Jakarta Sans) and curated color schemes.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Responsive Dark Mode:</strong> Smooth transition between Claude-inspired Sand Palette (light mode) and executive high-contrast Carbon Palette (dark mode).</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Multi-View Workspace:</strong> Pre-built specialized sub-views for AI Conversational Chat, AI Image Generation, AI Video Creation, Code Playground, and Workspace Asset Library.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Micro-Interactions & Motion:</strong> Fluid dropdown transitions, staggered list item reveals, and smooth blurred entry animations.</span>
						</li>
						<li class="flex items-start gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200 mt-0.5 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong class="text-zinc-200">Workspace & Account Management:</strong> Sleek collapsible navigation sidebar featuring interactive space switcher dropdowns.</span>
						</li>
					</ul>
				</div>

				<div class="space-y-4">
					<h2 class="font-bold text-2xl text-zinc-200" style="font-family: var(--font-display)">What's Included</h2>
					<ul class="space-y-2 text-zinc-400">
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Full Source Code: Clean, well-structured Angular 22 & Tailwind CSS v4 template code
						</li>
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Developer Guidelines (DEVELOPER_GUIDE.md): Detailed setup, design system guide, component API schema
						</li>
						<li class="flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-200"><polyline points="20 6 9 17 4 12"/></svg>
							Commercial License (LICENSE.md): Fully cleared for commercial SaaS, internal portals, and client web app deliverables
						</li>
					</ul>
				</div>

				<div class="space-y-4">
					<h2 class="font-bold text-2xl text-zinc-200" style="font-family: var(--font-display)">Tech Stack</h2>
					<div class="flex flex-wrap gap-2">
						{template.tech.map(tech => (
							<span class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-zinc-900 text-zinc-300 border border-zinc-800">{tech}</span>
						))}
					</div>
				</div>
			</div>
		</div>
		<Analytics />
	</body>
</html>
